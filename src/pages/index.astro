---
import Layout from '../layouts/Layout.astro';
---

<Layout>
  <main class="page-shell">
    <!-- Top navigation removed per user request (redundant with in-page tabs) -->

    <section class="hero" id="home">
      <div>
        <p class="eyebrow">Graduate Student in Computer Science</p>
        <h1 class="site-title">Shou-Wei Tsai (蔡劭威)</h1>
        <p class="lead">
          Graduated with a background in Statistics and have spent the past years strengthening my skills in
          data analysis, machine learning, sensing peripheral devices (FPGA/Raspberry Pi) and applied
          computational research. My interests lie in combining statistical reasoning with software and hardware
          understanding to solve real-world problems.
        </p>
        <div class="hero-actions">
          <a href="#projects">Selected Projects</a>
          <a href="#education" class="secondary resume-btn">Resume / CV</a>
          <a href="#contact" class="secondary contact-btn">Contact</a>
        </div>
      </div>
      <div class="hero-visual">
        <div class="profile-photo-wrap">
          <img
            class="profile-photo"
            src="/your-photo.jpg"
            alt="Tsai Shou-Wei"
          />
        </div>
      </div>
    </section>

    <section class="section" id="education">
      <div class="section-header">
        <p class="eyebrow">Education</p>
        <h2>Academic Background</h2>
      </div>
      <div class="education-grid">
        <article class="education-card">
          <p class="education-year">2021/09 — 2025/06</p>
          <h3>National Cheng Kung University</h3>
          <p class="education-major">Department of Statistics</p>
        </article>
        <article class="education-card">
          <p class="education-year">2025/09 — 2026/07</p>
          <h3>National Taiwan University of Science and Technology</h3>
          <p class="education-major">Department of Computer Science and Information Engineering</p>
        </article>
        <article class="education-card">
          <p class="education-year">2026/08 — Present</p>
          <h3>National Yang Ming Chiao Tung University</h3>
          <p class="education-major">Department of Computer Science</p>
        </article>
      </div>
    </section>

    <section class="section" id="experience">
      <div class="section-header">
        <p class="eyebrow">Research experience</p>
        <h2>Areas of Study</h2>
      </div>
      <div class="experience-layout">
        <div>
          <p class="experience-text">
            My academic path spans statistics, statistical signal processing, machine learning, and hardware-oriented
            computing. I have worked with point clouds, probabilistic methods, denoising strategies, and large-scale
            data analysis, while also exploring embedded systems and digital design.
          </p>
        </div>
        <div class="tag-panel">
          <p class="tag-title">Research Focus</p>
          <div class="tag-list tag-list-inline">
            <span>Big Data Analysis</span>
            <span>Probability & Mathematical Statistics</span>
            <span>Machine Learning and Deep Learning</span>
            <span>Freezing of Gate Detection</span>
            <span>Signal Processing</span>
          </div>
        </div>
      </div>
    </section>

    <section class="section" id="projects">
      <div class="section-header">
        <p class="eyebrow">Projects</p>
        <h2>Selected Work</h2>
      </div>
      <div class="project-grid">
        <article class="project-card">
          <div class="project-top">
            <p class="project-meta">Research · 3D vision</p>
            <span class="project-pill">Point Clouds</span>
          </div>
          <h3>3D Point Cloud Registration on Forest Datasets</h3>
          <p>
            Studied registration pipelines for TLS and ULS datasets, focusing on robustness under noisy and partially
            overlapping point sets.
          </p>
        </article>
        <article class="project-card">
          <div class="project-top">
            <p class="project-meta">Statistics · Modeling</p>
            <span class="project-pill">Probabilistic Methods</span>
          </div>
          <h3>Markov Chain Based Outlier Denoising</h3>
          <p>
            Investigated probabilistic self-update strategies to improve inlier recovery and reduce the impact of outliers.
          </p>
        </article>
        <article class="project-card">
          <div class="project-top">
            <p class="project-meta">Coursework · Algorithms</p>
            <span class="project-pill">Implementation</span>
          </div>
          <h3>Algorithms and Data Analysis Projects</h3>
          <p>
            Implemented and analyzed KNN, K-means, DBSCAN, decision trees, and related methods for data exploration and evaluation.
          </p>
        </article>
        <article class="project-card">
          <div class="project-top">
            <p class="project-meta">Hardware · Embedded</p>
            <span class="project-pill">Systems</span>
          </div>
          <h3>Raspberry Pi 5 Embedded Sensing System</h3>
          <p>
            Built a real-time vibration and FFT analysis setup using sensors, Linux-based control, and signal processing pipelines.
          </p>
        </article>
        <article class="project-card">
          <div class="project-top">
            <p class="project-meta">Digital Design</p>
            <span class="project-pill">FPGA</span>
          </div>
          <h3>FPGA / Verilog / VHDL Coursework</h3>
          <p>
            Worked on datapath design, RTL simulation, and hardware verification for processor and logic-focused projects.
          </p>
        </article>
        <article class="project-card">
          <div class="project-top">
            <p class="project-meta">Applied AI</p>
            <span class="project-pill">NLP & vision</span>
          </div>
          <h3>Hate Speech Detection and Disaster Prediction with NLP</h3>
          <p>
            Explored text classification and prediction tasks using data-driven methods and applied modeling workflows.
          </p>
        </article>
      </div>
    </section>

    <section class="section contact-section" id="contact">
      <div class="section-header">
        <p class="eyebrow">Contact</p>
        <h2>Contact Information</h2>
      </div>
      <div class="contact-meta-block">
        <p><strong>Hobbies:</strong> Bodybuilding, Basketball, Language learning</p>
        <p><strong>Locations:</strong> Hsinchu, Taipei, Tainan, Taiwan (R.O.C)</p>
      </div>
      <p>
        Welcome for research collaboration, applied data projects, and opportunities related to AI, statistics,
        and intelligent systems.
      </p>
      <div class="contact-links">
        <a href="mailto:h24101329@gs.ncku.edu.tw">h24101329@gs.ncku.edu.tw</a>
        <a href="https://github.com/mrdrano" target="_blank" rel="noreferrer">GitHub</a>
        <a href="https://www.linkedin.com/in/%E5%8A%AD%E5%A8%81-%E8%94%A1-58b752258/" target="_blank" rel="noreferrer">LinkedIn</a>
        <a href="https://hackmd.io/@ddrano?utm_source=overview&utm_medium=team-switcher" target="_blank" rel="noreferrer">HackMD</a>
      </div>
    </section>
  </main>
</Layout>

<div class="edge-decor" aria-hidden="true">
  <span class="h-line"></span>
  <span class="v-line left"></span>
  <span class="v-line right"></span>
  <span class="dot" style="left:14%; top:28px"></span>
  <span class="dot" style="left:34%; top:24px"></span>
  <span class="dot" style="left:64%; top:30px"></span>
  <span class="corner top-left"></span>
  <span class="corner top-right"></span>
  <span class="label-badge" style="left:8%; top:68px">Areas of study</span>
  <span class="label-badge right" style="right:8%; top:68px">Selected projects</span>
  <div class="floating-panel" style="right:6%; top:120px">
    <div class="row"><span class="dot-mini"></span><div>Recent: Graph ML paper</div></div>
    <div class="row"><span class="dot-mini"></span><div>Tooling: Compiler experiments</div></div>
    <div class="row"><span class="dot-mini"></span><div>Location: Taipei</div></div>
  </div>
  <svg class="svg-pattern" width="84" height="48" viewBox="0 0 84 48" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
    <defs>
      <pattern id="p" width="6" height="6" patternUnits="userSpaceOnUse">
        <rect width="1" height="1" fill="rgba(16,24,40,0.08)"></rect>
      </pattern>
    </defs>
    <rect width="84" height="48" fill="url(#p)" />
  </svg>
</div>

<div class="crab" aria-hidden="true">🦀</div>

<script>
  (function() {
    const crab = document.querySelector('.crab');
    if (!crab) return;

    // When pointer enters the crab, pause its walking animation; when it leaves, resume.
    function pause() {
      crab.style.animationPlayState = 'paused';
      crab.classList.add('paused-by-pointer');
    }

    function resume() {
      crab.style.animationPlayState = '';
      crab.classList.remove('paused-by-pointer');
    }

    // pointerenter/pointerleave cover mouse and stylus; use touch events for mobile
    crab.addEventListener('pointerenter', pause);
    crab.addEventListener('pointerleave', resume);

    crab.addEventListener('touchstart', function(e) {
      pause();
      // resume after finger lifts
      const onEnd = () => { resume(); window.removeEventListener('touchend', onEnd); };
      window.addEventListener('touchend', onEnd, {passive:true});
    }, {passive:true});

    // also allow clicking the crab to toggle pause/resume for fun
    crab.addEventListener('click', function() {
      if (crab.classList.contains('paused-by-pointer')) resume(); else pause();
    });
  })();
</script>

<style>
  :root {
    --bg: #f8fafc;
    --surface: #ffffff;
    --surface-2: #f1f5f9;
    --text: #0b1220;
    --muted: #64748b;
    --accent: #2563eb;
    --accent-2: #7c3aed;
    --border: #e6edf3;
  }

  html {
    scroll-behavior: smooth;
  }

  body {
    background: linear-gradient(180deg, #ffffff 0%, #f8fafc 100%);
    color: var(--text);
  }

  .page-shell {
    width: min(1120px, calc(100% - 48px));
    margin: 0 auto;
    padding: 72px 0 64px;
  }

  .top-nav {
    display: flex;
    justify-content: flex-end;
    gap: 18px;
    margin-bottom: 32px;
  }

  .top-nav a {
    color: var(--muted);
    text-decoration: none;
    font-size: 0.95rem;
  }

  .hero,
  .section {
    margin-bottom: 48px;
  }

  .hero {
    display: grid;
    grid-template-columns: 1.5fr 0.9fr;
    gap: 32px;
    align-items: start;
    padding: 24px 0 36px;
  }

  .eyebrow {
    text-transform: uppercase;
    letter-spacing: 0.18em;
    font-size: 0.76rem;
    color: var(--accent);
    margin: 0 0 8px;
  }

  h1,
  h2,
  h3,
  p {
    margin: 0;
  }

  h1 {
    font-size: clamp(2.6rem, 3.4vw, 3.8rem);
    line-height: 1;
    margin-bottom: 12px;
  }

  .site-title {
    font-size: clamp(2.1rem, 2.8vw, 3rem);
  }

  .lead {
    color: var(--muted);
    font-size: 1rem;
    line-height: 1.8;
    max-width: 65ch;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin-top: 18px;
  }

  .hero > div:first-child {
    align-self: start;
  }

  .hero-actions a,
  .contact-links a,
  .repo-card {
    color: var(--text);
    text-decoration: none;
  }

  .hero-actions a {
    display: inline-block;
    padding: 0.8rem 1rem;
    background: linear-gradient(90deg, var(--accent), var(--accent-2));
    color: #0b1120;
    font-weight: 600;
    border-radius: 999px;
  }

  .hero-actions a.secondary {
    background: transparent;
    color: var(--text);
    border: 1px solid var(--border);
  }

  .resume-btn {
    background: transparent;
  }

  /* Colored action buttons */
  .hero-actions a.resume-btn {
    background: linear-gradient(90deg, #10b981, #059669); /* green */
    color: #061014;
    border: none;
  }

  .hero-actions a.contact-btn {
    background: linear-gradient(90deg, #fbbf24, #f59e0b); /* yellow */
    color: #061014;
    border: none;
  }

  /* Subtle border accents */
  .hero-actions a {
    box-shadow: inset 0 0 0 1px rgba(255,255,255,0.03);
  }

  .hero-actions a.secondary {
    box-shadow: none; /* secondary already has its own border */
  }

  .hero-visual .profile-photo-wrap {
    border-radius: 20px;
    border: 1px solid rgba(125,211,252,0.06);
    box-shadow: 0 8px 20px rgba(2,6,23,0.45);
  }

  .hero-card {
    padding: 24px;
    border: 1px solid rgba(255,255,255,0.03);
    box-shadow: 0 6px 18px rgba(2,6,23,0.45);
  }

  .hero-card,
  .education-card,
  .project-card,
  .repo-card,
  .contact-section {
    background: linear-gradient(180deg, var(--surface), var(--surface-2));
    border: 1px solid var(--border);
    border-radius: 18px;
  }

  .hero-visual {
    display: grid;
    gap: 18px;
    align-content: start;
  }

  .profile-photo-wrap {
    overflow: hidden;
    border-radius: 18px;
    border: 1px solid var(--border);
    background: var(--surface-2);
    max-width: 360px;
    margin-left: auto;
  }

  .profile-photo {
    display: block;
    width: 100%;
    aspect-ratio: 1 / 1;
    object-fit: cover;
    max-width: 320px;
    margin: 0 auto;
  }

  .hero-card {
    padding: 24px;
  }

  .card-label {
    color: var(--muted);
    font-size: 0.9rem;
    margin-bottom: 14px;
  }

  .hero-card ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 10px;
  }

  .hero-card li {
    color: var(--text);
    position: relative;
    padding-left: 18px;
  }

  .hero-card li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.6em;
    width: 6px;
    height: 6px;
    background: var(--accent);
    border-radius: 50%;
  }

  .section-header {
    margin-bottom: 18px;
  }

  .section-header h2 {
    font-size: 1.8rem;
  }

  .education-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 18px;
  }

  .education-card {
    padding: 22px;
  }

  .education-year {
    color: var(--accent);
    font-size: 0.85rem;
    margin-bottom: 8px;
  }

  .education-major {
    color: var(--muted);
    margin-top: 6px;
    line-height: 1.6;
  }

  .experience-layout {
    display: grid;
    grid-template-columns: 1fr 1.1fr;
    gap: 18px;
  }

  .experience-text {
    color: var(--muted);
    line-height: 1.8;
  }

  .tag-list {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
  }

  .tag-panel {
    display: grid;
    gap: 10px;
    align-content: start;
  }

  .tag-title {
    color: var(--accent);
    font-size: 0.9rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .tag-list-inline {
    align-content: flex-start;
    justify-content: flex-start;
  }

  .tag-list span {
    padding: 0.6rem 0.8rem;
    background: rgba(125, 211, 252, 0.08);
    border: 1px solid var(--border);
    border-radius: 999px;
    color: var(--text);
  }

  .project-grid,
  .repo-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 18px;
  }

  .project-card {
    padding: 22px;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .project-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
  }

  .project-meta {
    color: var(--accent);
    font-size: 0.85rem;
    margin: 0;
  }

  .project-pill {
    font-size: 0.78rem;
    color: var(--text);
    background: rgba(192, 132, 252, 0.1);
    border: 1px solid var(--border);
    padding: 0.35rem 0.55rem;
    border-radius: 999px;
  }

  .project-card p:last-child {
    color: var(--muted);
    line-height: 1.7;
  }

  .repo-card {
    padding: 20px;
    display: block;
  }

  .repo-note {
    color: var(--muted);
    margin-bottom: 16px;
  }

  .repo-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    margin-bottom: 8px;
  }

  .repo-tag {
    font-size: 0.78rem;
    color: var(--text);
    background: rgba(125, 211, 252, 0.08);
    border: 1px solid var(--border);
    padding: 0.3rem 0.5rem;
    border-radius: 999px;
  }

  .repo-card p {
    color: var(--muted);
    line-height: 1.7;
  }

  .contact-section {
    padding: 28px;
  }

  .contact-meta-block {
    display: grid;
    gap: 6px;
    margin-bottom: 18px;
  }

  .contact-meta-block p {
    color: var(--muted);
    line-height: 1.7;
  }

  .contact-section > p {
    color: var(--muted);
    line-height: 1.7;
    margin-bottom: 18px;
  }

  .contact-links {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
  }

  .contact-links a {
    padding: 0.7rem 0.9rem;
    border: 1px solid var(--border);
    border-radius: 999px;
  }

  /* Dynamic accents and hover effects */
  @keyframes floatY {
    0% { transform: translateY(0); }
    50% { transform: translateY(-6px); }
    100% { transform: translateY(0); }
  }

  .profile-photo-wrap:hover {
    transform: translateY(-6px) scale(1.01);
    transition: transform 300ms ease, box-shadow 300ms ease;
    box-shadow: 0 14px 30px rgba(16,24,40,0.12);
  }

  .profile-photo-wrap {
    transition: transform 350ms ease, box-shadow 350ms ease;
  }

  .hero-actions a:hover {
    transform: translateY(-4px) scale(1.02);
    transition: transform 180ms ease, box-shadow 180ms ease;
    box-shadow: 0 10px 20px rgba(16,24,40,0.08);
  }

  .project-card:hover {
    transform: translateY(-8px);
    transition: transform 240ms ease, box-shadow 240ms ease;
    box-shadow: 0 18px 36px rgba(16,24,40,0.06);
  }

  .tag-list span:hover {
    transform: translateY(-3px);
    background: linear-gradient(90deg, rgba(37,99,235,0.08), rgba(124,58,237,0.06));
    transition: transform 180ms ease, background 220ms ease;
  }

  /* subtle moving gradient accent behind hero */
  .page-shell::before {
    content: '';
    position: absolute;
    left: 50%;
    top: -120px;
    width: 720px;
    height: 360px;
    transform: translateX(-50%);
    background: radial-gradient(closest-side, rgba(37,99,235,0.06), transparent 60%);
    filter: blur(36px);
    pointer-events: none;
    animation: floatY 8s ease-in-out infinite;
    z-index: 0;
  }

  /* Ensure content sits above decorative pseudo element */
  .page-shell > * {
    position: relative;
    z-index: 1;
  }

  /* Crab animation element (walk along top edge) */
  .crab {
    position: fixed;
    top: 12px;
    left: -160px;
    font-size: 48px;
    z-index: 9999;
    pointer-events: auto;
    transform: translateX(0) translateY(0);
    animation: crabWalkTop 14s linear infinite;
    will-change: transform;
    filter: drop-shadow(0 8px 12px rgba(16,24,40,0.12));
  }

  @keyframes crabWalkTop {
    0% {
      transform: translateX(0) translateY(0);
      opacity: 1;
    }
    10% { transform: translateX(10vw) translateY(4px); }
    30% { transform: translateX(35vw) translateY(0px); }
    50% { transform: translateX(60vw) translateY(6px); }
    70% { transform: translateX(80vw) translateY(2px); }
    90% { transform: translateX(95vw) translateY(4px); }
    100% { transform: translateX(calc(100vw + 180px)) translateY(0); opacity: 0; }
  }

  /* Edge decorations: subtle lines, dots, and corner accents */
  .edge-decor {
    position: fixed;
    inset: 0;
    pointer-events: none;
    z-index: 850;
  }

  .edge-decor .h-line {
    position: absolute;
    left: 6%;
    right: 6%;
    height: 1px;
    top: 44px;
    background: linear-gradient(90deg, transparent, rgba(16,24,40,0.06), transparent);
    opacity: 0.95;
    filter: blur(0.2px);
  }

  .edge-decor .v-line.left {
    position: absolute;
    top: 10%;
    bottom: 10%;
    left: 6%;
    width: 1px;
    background: linear-gradient(180deg, transparent, rgba(16,24,40,0.04), transparent);
    opacity: 0.9;
  }

  .edge-decor .v-line.right {
    position: absolute;
    top: 10%;
    bottom: 10%;
    right: 6%;
    width: 1px;
    background: linear-gradient(180deg, transparent, rgba(16,24,40,0.04), transparent);
    opacity: 0.9;
  }

  .edge-decor .dot {
    position: absolute;
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: rgba(16,24,40,0.05);
    box-shadow: 0 2px 4px rgba(16,24,40,0.03);
  }

  .edge-decor .corner {
    position: absolute;
    width: 18px;
    height: 18px;
    border: 1px solid rgba(16,24,40,0.06);
    border-radius: 2px;
    background: linear-gradient(180deg, rgba(255,255,255,0.02), transparent);
  }

  .edge-decor .corner.top-left { left: 5.2%; top: 10px; border-right: none; border-bottom: none; }
  .edge-decor .corner.top-right { right: 5.2%; top: 10px; border-left: none; border-bottom: none; }

  /* hide decorations on small screens to avoid clutter */
  @media (max-width: 720px) {
    .edge-decor { display: none; }
  }

  /* UI/UX border micro-interactions */
  .edge-decor .label-badge {
    position: absolute;
    top: 64px;
    left: 6%;
    background: rgba(16,24,40,0.03);
    color: rgba(16,24,40,0.8);
    padding: 6px 10px;
    border-radius: 6px;
    font-size: 13px;
    letter-spacing: 0.2px;
    border: 1px solid rgba(16,24,40,0.04);
    backdrop-filter: blur(4px);
    transition: transform 220ms ease, opacity 220ms ease;
    transform-origin: left top;
  }

  .edge-decor .label-badge.right {
    left: auto;
    right: 6%;
  }

  .edge-decor .floating-panel {
    position: absolute;
    right: 6%;
    top: 120px;
    width: 200px;
    padding: 12px;
    background: linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0));
    border: 1px solid rgba(16,24,40,0.04);
    border-radius: 10px;
    box-shadow: 0 8px 20px rgba(16,24,40,0.04);
    font-size: 13px;
    color: rgba(16,24,40,0.85);
    opacity: 0.95;
    transform: translateY(0);
